{
  "name": "maru",
  "version": "0.4.11",
  "private": true,
  "type": "module",
  "description": "Local-first Maru Workspace and AI editing desktop app.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5307",
    "build": "tsc -b && vite build && node scripts/check-bundle-budget.mjs",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "lint:i18n": "node scripts/lint-i18n.mjs",
    "preview": "vite preview --host 127.0.0.1 --port 5308",
    "tauri": "tauri",
    "clean:tauri-bundles": "node scripts/clean-tauri-bundles.mjs",
    "clean:tauri-debug": "node scripts/prune-tauri-debug.mjs",
    "tauri:dev": "pnpm clean:tauri-bundles && pnpm clean:tauri-debug && tauri dev",
    "tauri:build": "pnpm clean:tauri-bundles && pnpm clean:tauri-debug && tauri build",
    "test": "vitest run src",
    "test:e2e": "playwright test",
    "test:e2e:graph": "playwright test e2e/graph.spec.ts e2e/graph-shell.spec.ts",
    "bench:graph": "vitest bench src/lib/graph/perf.bench.ts --run",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@blocknote/core": "^0.49.0",
    "@blocknote/mantine": "^0.49.0",
    "@blocknote/react": "^0.49.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sigma/export-image": "3.0.0",
    "@sigma/node-border": "3.0.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "@types/dompurify": "^3.2.0",
    "date-fns": "^3.0.0",
    "dompurify": "^3.4.1",
    "graphology": "0.26.0",
    "graphology-layout": "0.6.1",
    "graphology-layout-forceatlas2": "0.10.1",
    "lucide-react": "^0.564.0",
    "marked": "^18.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.7.0",
    "sigma": "3.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.10.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "graphology-types": "0.24.8",
    "jsdom": "^29.1.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.5"
  }
}
