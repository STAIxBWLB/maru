#!/bin/bash
# xlsx-toolkit wrapper — read/summary/to-csv/to-md subcommands
#
# Usage:
#   ./xlsx read <file.xlsx> [--sheet N|name] [--max-rows N] [--values-only]
#   ./xlsx summary <file.xlsx>
#   ./xlsx to-csv <file.xlsx> [--sheet N] [-o out.csv] [--all-sheets]
#   ./xlsx to-md  <file.xlsx> [--sheet N]

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

# Resolve the Anchor skills python interpreter, most-specific first.
# Honors $SKILL_PYTHON, then host-injected $ANCHOR_SKILLS_ENV,
# then the canonical ~/.anchor/env, then a repo-local walk-up (dev-in-tree).
# Canonical snippet — keep in sync with skills/envs/default/REFERENCE.md.
find_env_python() {
    local c dir
    if [ -n "${SKILL_PYTHON:-}" ] && [ -x "${SKILL_PYTHON}" ]; then
        printf '%s\n' "$SKILL_PYTHON"; return 0
    fi
    for c in \
        "${ANCHOR_SKILLS_ENV:+$ANCHOR_SKILLS_ENV/.venv/bin/python3}" \
        "$HOME/.anchor/env/.venv/bin/python3"; do
        [ -n "$c" ] && [ -x "$c" ] && printf '%s\n' "$c" && return 0
    done
    dir="$SCRIPT_DIR"
    while [ "$dir" != "/" ]; do
        for c in \
            "$dir/env/.venv/bin/python3" \
            "$dir/envs/default/.venv/bin/python3" \
            "$dir/skills/envs/default/.venv/bin/python3"; do
            [ -x "$c" ] && printf '%s\n' "$c" && return 0
        done
        dir="$(dirname "$dir")"
    done
    return 1
}

VENV_PY="$(find_env_python || true)"
if [ -z "$VENV_PY" ] || [ ! -x "$VENV_PY" ]; then
    if command -v python3 >/dev/null 2>&1; then
        VENV_PY="$(command -v python3)"
        echo "[xlsx-toolkit] ~/.anchor/env/.venv 미발견, system python3 fallback: $VENV_PY" >&2
    else
        echo "[xlsx-toolkit] python 없음. 'bash ~/.anchor/skills/_builtin/envs/default/setup.sh --target ~/.anchor/env' 실행" >&2
        exit 1
    fi
fi

# Export the resolved runtime so venv/node-based steps work in a bare session too.
case "$VENV_PY" in
    */.venv/bin/python3)
        _ENV_ROOT="$(cd "$(dirname "$VENV_PY")/../.." && pwd -P)"
        export VIRTUAL_ENV="$_ENV_ROOT/.venv"
        case ":$PATH:" in *":$_ENV_ROOT/.venv/bin:"*) ;; *) PATH="$_ENV_ROOT/.venv/bin:$PATH";; esac
        export PATH
        if [ -d "$_ENV_ROOT/node_modules" ]; then
            case ":${NODE_PATH:-}:" in *":$_ENV_ROOT/node_modules:"*) ;; *) NODE_PATH="$_ENV_ROOT/node_modules${NODE_PATH:+:$NODE_PATH}"; export NODE_PATH;; esac
        fi
        ;;
esac

if [ $# -eq 0 ]; then
    cat <<USAGE
xlsx-toolkit — Excel(.xlsx) 파일 read-only 처리

Usage: ./xlsx <command> [args...]

Commands:
  read       셀 값 추출 → markdown 표
  summary    시트 목록 + 행/열 카운트
  to-csv     CSV 출력
  to-md      markdown 표 출력

Options (commands별 상이):
  --sheet <N|name>   시트 번호(1-based) 또는 이름
  --max-rows <N>     처음 N행만
  --values-only      수식 대신 캐시 값
  -o, --output <f>   파일 출력 (기본 stdout)
  --all-sheets       시트별로 각각 처리

Examples:
  ./xlsx read budget.xlsx
  ./xlsx summary budget.xlsx
  ./xlsx to-csv budget.xlsx --sheet "2026" -o budget-2026.csv
  ./xlsx to-md budget.xlsx --sheet 1
USAGE
    exit 0
fi

exec "$VENV_PY" "$SCRIPT_DIR/scripts/xlsx_cli.py" "$@"
