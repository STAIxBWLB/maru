#!/bin/bash
# pptx-toolkit wrapper — read/outline/notes/to-md subcommands
#
# Usage:
#   ./pptx read    <file.pptx> [--slide N]
#   ./pptx outline <file.pptx>
#   ./pptx notes   <file.pptx> [--slide N]
#   ./pptx to-md   <file.pptx> [-o out.md]

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

# Resolve the Anchor skills python interpreter, most-specific first.
# Honors $SKILL_PYTHON, then host-injected $ANCHOR_SKILLS_ENV,
# then the canonical ~/.anchor/env, then a repo-local walk-up (dev-in-tree).
# Canonical snippet — keep in sync with skills/envs/default/REFERENCE.md.
find_env_python() {
    local c dir
    if [ -n "${SKILL_PYTHON:-}" ] && [ -x "${SKILL_PYTHON}" ]; then
        printf '%s\n' "$SKILL_PYTHON"; return 0
    fi
    for c in \
        "${ANCHOR_SKILLS_ENV:+$ANCHOR_SKILLS_ENV/.venv/bin/python3}" \
        "$HOME/.anchor/env/.venv/bin/python3"; do
        [ -n "$c" ] && [ -x "$c" ] && printf '%s\n' "$c" && return 0
    done
    dir="$SCRIPT_DIR"
    while [ "$dir" != "/" ]; do
        for c in \
            "$dir/env/.venv/bin/python3" \
            "$dir/envs/default/.venv/bin/python3" \
            "$dir/skills/envs/default/.venv/bin/python3"; do
            [ -x "$c" ] && printf '%s\n' "$c" && return 0
        done
        dir="$(dirname "$dir")"
    done
    return 1
}

VENV_PY="$(find_env_python || true)"
if [ -z "$VENV_PY" ] || [ ! -x "$VENV_PY" ]; then
    if command -v python3 >/dev/null 2>&1; then
        VENV_PY="$(command -v python3)"
        echo "[pptx-toolkit] ~/.anchor/env/.venv 미발견, system python3 fallback: $VENV_PY" >&2
    else
        echo "[pptx-toolkit] python 없음. 'bash ~/.anchor/skills/_builtin/envs/default/setup.sh --target ~/.anchor/env' 실행" >&2
        exit 1
    fi
fi

# Export the resolved runtime so venv/node-based steps work in a bare session too.
case "$VENV_PY" in
    */.venv/bin/python3)
        _ENV_ROOT="$(cd "$(dirname "$VENV_PY")/../.." && pwd -P)"
        export VIRTUAL_ENV="$_ENV_ROOT/.venv"
        case ":$PATH:" in *":$_ENV_ROOT/.venv/bin:"*) ;; *) PATH="$_ENV_ROOT/.venv/bin:$PATH";; esac
        export PATH
        if [ -d "$_ENV_ROOT/node_modules" ]; then
            case ":${NODE_PATH:-}:" in *":$_ENV_ROOT/node_modules:"*) ;; *) NODE_PATH="$_ENV_ROOT/node_modules${NODE_PATH:+:$NODE_PATH}"; export NODE_PATH;; esac
        fi
        ;;
esac

if [ $# -eq 0 ]; then
    cat <<USAGE
pptx-toolkit — PowerPoint(.pptx) read-only CLI

Usage: ./pptx <command> [args...]

Commands:
  read       슬라이드 텍스트 + 노트 → markdown
  outline    슬라이드 제목 목록
  notes      발표자 노트만 추출
  to-md      markdown 변환 (파일 저장)

Options:
  --slide <N>      특정 슬라이드 번호 (1-based)
  -o, --output     저장 파일 (기본 stdout)

Examples:
  ./pptx outline presentation.pptx
  ./pptx read presentation.pptx --slide 5
  ./pptx notes presentation.pptx
  ./pptx to-md presentation.pptx -o deck.md
USAGE
    exit 0
fi

exec "$VENV_PY" "$SCRIPT_DIR/scripts/pptx_cli.py" "$@"
