{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/init-env.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(.venv/bin/*)",
      "Bash(uv *)",
      "Bash(./setup.sh)"
    ]
  }
}
